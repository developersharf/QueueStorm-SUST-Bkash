# --- Required in every environment ----------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me

# "True" or anything else = False. Production must be False.
DEBUG=False

# Comma-separated. Railway domains are added automatically if you use *.railway.app.
ALLOWED_HOSTS=.railway.app,.up.railway.app,localhost,127.0.0.1

# Comma-separated full origins, e.g. https://ticketsort.up.railway.app
CSRF_TRUSTED_ORIGINS=https://*.railway.app,https://*.up.railway.app,http://localhost:8000

# --- Database --------------------------------------------------------------
# Railway injects DATABASE_URL when you attach a Postgres plugin.
# Locally, leave it blank to fall back to a project-local SQLite file.
DATABASE_URL=

# --- Gunicorn tuning (optional) --------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
PORT=8000